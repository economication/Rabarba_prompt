ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Model config (override defaults here)
# Note: claude-sonnet-4-5 is the configured default. If using an older API tier,
# set this to a valid model such as: claude-3-5-sonnet-20241022
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o-mini

# Optional — increases GitHub API rate limit from 60 to 5000 req/hour
# Private repository support requires repo scope (Wave 3)
GITHUB_TOKEN=
